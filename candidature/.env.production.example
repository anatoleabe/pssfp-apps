# =====================================================================
# candidature.pssfp.net — variables de PRODUCTION (template)
# =====================================================================
# Sur le serveur : copier en `.env.production` (gitignored) et renseigner
# les valeurs. Toutes les variables NEXT_PUBLIC_* sont PUBLIQUES (incluses
# dans le bundle client) — n'y mettre aucun secret.
# Ne PAS committer le `.env.production` réel.
# =====================================================================

# API Laravel (préfixe /v1 inclus).
NEXT_PUBLIC_API_URL=https://api.pssfp.net/v1

# Site institutionnel (liens retour dans le header/accueil).
NEXT_PUBLIC_MAIN_SITE_URL=https://pssfp.net

# Cloudflare Turnstile — clé PUBLIQUE (site key). À créer dans le dashboard
# Cloudflare pour le domaine candidature.pssfp.net. Laisser vide désactive le
# captcha côté front (le backend fait autorité).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Sentry (facultatif) — DSN public de monitoring des erreurs front.
NEXT_PUBLIC_SENTRY_DSN=
