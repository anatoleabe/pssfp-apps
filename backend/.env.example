APP_NAME=PSSFP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Douala
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pssfp
DB_USERNAME=pssfp_admin
DB_PASSWORD=__a_definir__

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=minio
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=pssfp

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@pssfp.net"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum stateful domains — comma-separated
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:6001,localhost:6002,localhost:6003

# Filament admin
FILAMENT_REQUIRE_2FA=true
FILAMENT_ADMIN_EMAIL=__a_definir__
FILAMENT_ADMIN_PASSWORD=__a_definir__

# Meilisearch
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=__a_definir__

# MinIO / S3
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_KEY=__a_definir__
MINIO_SECRET=__a_definir__
MINIO_REGION=us-east-1
MINIO_BUCKET=pssfp-media
MINIO_USE_PATH_STYLE_ENDPOINT=true

# SMS — fake (logs uniquement) en dev, africas_talking en prod
SMS_PROVIDER=fake
AFRICAS_TALKING_USERNAME=__a_definir__
AFRICAS_TALKING_API_KEY=__a_definir__
AFRICAS_TALKING_SENDER_ID=PSSFP

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"
