# Backend testing env — utilisé par CI (cp .env.testing.example .env.testing)
# Localement : docker-compose up -d postgres puis cp .env.testing.example .env.testing
APP_NAME=PSSFP
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=warning

# PostgreSQL — les migrations Module 5 nécessitent Postgres (advisory lock + regex)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pssfp_test
DB_USERNAME=pssfp_admin
DB_PASSWORD=pssfp_test_password

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

PULSE_ENABLED=false
TELESCOPE_ENABLED=false

# SMS provider stubbed for CI / local — never hits the network.
SMS_PROVIDER=fake
