<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- Garde-fous OTP neutralisés par défaut (les tests dédiés les
             réactivent via config()->set), même approche que Turnstile. -->
        <env name="OTP_COOLDOWN_SECONDS" value="0"/>
        <env name="OTP_MAX_PER_PHONE_PER_HOUR" value="1000"/>
        <!--
            DB_CONNECTION volontairement non forcé : les migrations Module 5
            utilisent pg_advisory_xact_lock + SUBSTRING regex + CHECK constraints,
            donc tous les tests tournent sur PostgreSQL. La config DB est lue
            depuis .env.testing (cf. .env.testing.example).
        -->
        <env name="REDIS_CLIENT" value="phpredis"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
