# =====================================================
# pssfp mono-repo — .env.example
# =====================================================
# Copier ce fichier vers .env et remplir les valeurs.
# Ne JAMAIS committer .env (cf. .gitignore).
# Les secrets de production sont stockés dans 1Password / Bitwarden
# du Chef USI uniquement, et dans les variables d'env du serveur.
# =====================================================

# -----------------------------
# General
# -----------------------------
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=fr

# -----------------------------
# PostgreSQL (cf. ADR-0002)
# -----------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pssfp
DB_USERNAME=pssfp_app
DB_PASSWORD=__a_definir__
# User admin séparé pour les migrations (DDL)
DB_ADMIN_USERNAME=pssfp_admin
DB_ADMIN_PASSWORD=__a_definir__

# -----------------------------
# Redis (cache, sessions, queue)
# -----------------------------
# REDIS_CLIENT=predis pour ne pas dépendre de l'extension PHP phpredis
# (requise uniquement si on bascule sur phpredis pour la perf en prod).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_DOMAIN=.pssfp.net
QUEUE_CONNECTION=redis

# -----------------------------
# Meilisearch (cf. ADR-0003)
# -----------------------------
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=__a_definir__
SCOUT_QUEUE=true

# -----------------------------
# MinIO (S3-compatible) - stockage local primaire
# -----------------------------
FILESYSTEM_DISK=minio
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=__a_definir__
MINIO_SECRET_KEY=__a_definir__
MINIO_REGION=us-east-1
MINIO_BUCKET_MEDIA=pssfp-media
MINIO_BUCKET_DOCUMENTS=pssfp-documents
MINIO_BUCKET_CANDIDATURES=pssfp-candidatures
MINIO_USE_PATH_STYLE_ENDPOINT=true

# -----------------------------
# Scaleway Object Storage - backups
# -----------------------------
SCALEWAY_BACKUP_ACCESS_KEY=__a_definir__
SCALEWAY_BACKUP_SECRET_KEY=__a_definir__
SCALEWAY_BACKUP_REGION=fr-par
SCALEWAY_BACKUP_BUCKET=pssfp-backups
SCALEWAY_BACKUP_ENDPOINT=https://s3.fr-par.scw.cloud

# -----------------------------
# Mail (creawebhosting SMTP)
# -----------------------------
MAIL_MAILER=smtp
MAIL_HOST=mail.creawebhosting.org
MAIL_PORT=465
MAIL_USERNAME=noreply@pssfp.net
MAIL_PASSWORD=__a_definir__
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@pssfp.net
MAIL_FROM_NAME="PSSFP"
MAIL_TO_CONTACT=contact@pssfp.net
MAIL_TO_ADMISSIONS=admissions@pssfp.net

# -----------------------------
# Sentry (cf. spec A10)
# -----------------------------
SENTRY_LARAVEL_DSN=__a_definir__
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# -----------------------------
# Cloudflare Turnstile (captcha)
# -----------------------------
TURNSTILE_SITE_KEY=__a_definir__
TURNSTILE_SECRET_KEY=__a_definir__

# -----------------------------
# Frontend Next.js (à dupliquer dans frontend/.env.local etc.)
# -----------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_LIBRARY_URL=http://localhost:3001
NEXT_PUBLIC_CANDIDATURE_URL=http://localhost:3002
NEXT_PUBLIC_FOAD_URL=https://foad.pssfp.net
NEXT_PUBLIC_TURNSTILE_SITE_KEY=__a_definir__
NEXT_PUBLIC_SENTRY_DSN=__a_definir__
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# -----------------------------
# Filament admin (seed initial — cf. AdminUserSeeder)
# -----------------------------
# FILAMENT_REQUIRE_2FA=false en dev — true en prod (enforcement câblé module 6).
FILAMENT_ADMIN_EMAIL=admin@pssfp.local
FILAMENT_ADMIN_PASSWORD=__a_definir_dev_uniquement__
FILAMENT_REQUIRE_2FA=false

# -----------------------------
# Sanctum / Auth
# -----------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,localhost:3002,pssfp.net,bibliotheque.pssfp.net,candidature.pssfp.net

# -----------------------------
# Logs
# -----------------------------
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=30
